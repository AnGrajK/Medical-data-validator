import re

REQUIRED_KEYS = {
    'patient_id', 'age', 'gender', 'diagnosis', 'medications', 'last_visit_id'
}

PATIENT_PATTERN = re.compile(r'^P\d{4}$', re.IGNORECASE)
VISIT_PATTERN = re.compile(r'^V\d{4}$', re.IGNORECASE)

medical_records = [
    {
        'patient_id': 'P1001',
        'age': 34,
        'gender': 'Female',
        'diagnosis': 'Hypertension',
        'medications': ['Lisinopril'],
        'last_visit_id': 'V2301',
    },
    {
        'patient_id': 'p1002',
        'age': 47,
        'gender': 'male',
        'diagnosis': 'Type 2 Diabetes',
        'medications': ['Metformin', 'Insulin'],
        'last_visit_id': 'v2302',
    },
    {
        'patient_id': 'P1003',
        'age': 29,
        'gender': 'female',
        'diagnosis': 'Asthma',
        'medications': ['Albuterol'],
        'last_visit_id': 'v2303',
    },
    {
        'patient_id': 'p1004',
        'age': 56,
        'gender': 'Male',
        'diagnosis': 'Chronic Back Pain',
        'medications': ['Ibuprofen', 'Physical Therapy'],
        'last_visit_id': 'V2304',
    }
]


def validate_record(record):
    """Validate a single medical record"""
    constraints = {
        'patient_id': isinstance(record['patient_id'], str) and PATIENT_PATTERN.match(record['patient_id']),
        'age': isinstance(record['age'], int) and record['age'] > 0,
        'gender': isinstance(record['gender'], str) and record['gender'].capitalize() in ['Male', 'Female'],
        'diagnosis': isinstance(record['diagnosis'], str) and record['diagnosis'].strip() != "",
        'medications': isinstance(record['medications'], list),
        'last_visit_id': isinstance(record['last_visit_id'], str) and VISIT_PATTERN.match(record['last_visit_id'])
    }

    return constraints


def validate(data):
    if not isinstance(data, (list, tuple)):
        print("Invalid format: expected a list or tuple.")
        return False

    is_invalid = False

    for index, record in enumerate(data):

        if not isinstance(record, dict):
            print(f"Invalid format: expected dictionary at position {index}")
            is_invalid = True
            continue

        if set(record.keys()) != REQUIRED_KEYS:
            print(f"Invalid keys in record at position {index}")
            is_invalid = True
            continue

        constraints = validate_record(record)

        for key, valid in constraints.items():
            if not valid:
                print(f"Unexpected format '{key}: {record[key]}' at position {index}")
                is_invalid = True

    if is_invalid:
        return False

    print("All records are valid.")
    return True


validate(medical_records)
